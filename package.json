{
  "name": "devtools",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @app/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r --parallel typecheck",
    "knip": "knip",
    "readme:status": "node scripts/readme-status.mjs",
    "readme:status:check": "node scripts/readme-status.mjs --check",
    "test": "vitest run --project '*:unit' --project '*:integration'",
    "test:unit": "vitest run --project '*:unit'",
    "test:integration": "vitest run --project '*:integration'",
    "test:watch": "vitest --project '*:unit'",
    "test:e2e": "pnpm --filter @app/web test:e2e",
    "gate": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm knip && pnpm readme:status:check && pnpm test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "catalog:",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "knip": "^6.27.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "typescript": "catalog:",
    "typescript-eslint": "^8.64.0",
    "vitest": "catalog:"
  }
}
