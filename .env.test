# Committeado: aquí NUNCA va un secreto real (CLAUDE.md).
# Las claves reales viven en .env / .env.test.local (gitignored).
NODE_ENV=test
LOG_LEVEL=silent

# Los tests reproducen la topología de PRODUCCIÓN: la app siempre detrás de un proxy de
# confianza (Cloudflare → Caddy → 127.0.0.1:WEB_PORT). Sin esto `clientIp()` ignoraría los
# headers de proxy —lo correcto para un origen expuesto a pelo— y los tests de rate limit
# por IP no podrían distinguir clientes. Ver apps/web/src/server/client-ip.ts.
TRUST_PROXY=1

# DATABASE_URL está deliberadamente ausente (testing/stack-setup.md §7): desde
# T0.3 la connection string la fabrica Testcontainers y viaja por provide/inject,
# así ninguna suite puede apuntar por accidente a la BD de desarrollo o del VPS.
