# deploy.env — configuración de despliegue del proyecto (SIN secretos: se committea).
# Lo rellena el bootstrap o la primera tarea de deploy. Los secretos reales viven
# SOLO en el .env del VPS (gitignored). Los scripts de .claude/skills/deploy/scripts/
# cargan este fichero y fallan con mensaje claro si quedan placeholders {{…}}.

# ── Identidad del proyecto ────────────────────────────────────────────────────
PROJECT_NAME="devtools"                  # slug: minúsculas y guiones (nombra contenedores, backups, dir remoto)
DOMAIN="devtools.carlosvillu.dev"        # dominio público, p.ej. app.example.com
WEB_PORT="3110"                          # bloque 3110–3119 reservado para devtools en ~/AGENTS.md §3.
                                         # T3.1 debe registrarlo ALLÍ al desplegar (lo exige ese fichero).
                                         # El compose de prod publica "127.0.0.1:3110:3000"; NUNCA en
                                         # 0.0.0.0 — un puerto abierto por docker se salta UFW.

# ── El VPS de producción ──────────────────────────────────────────────────────
VPS_IP="80.190.75.149"                   # IP pública del VPS (IPv4; también tiene IPv6)
VPS_SSH="developer@80.190.75.149"        # solo clave; BatchMode debe funcionar
REMOTE_DIR="/home/developer/projects/devtools"   # ruta ABSOLUTA del repo en el VPS

# ── Topología (defaults sensatos; cámbialos solo si tu VPS difiere) ──────────
COMPOSE_FILE="docker-compose.prod.yml"   # compose de producción, relativo a la raíz del repo
COMPOSE_PROJECT="$PROJECT_NAME"          # nombre de proyecto compose (prefijo de contenedores)
SERVICES="web postgres"                  # servicios a vigilar; añade "worker" si el módulo cola existe
WEB_SERVICE="web"                        # servicio con healthcheck que marca "la app está viva"
HEALTH_PATH="/api/health"                # endpoint que responde {"ok":true,"db":true}
VERIFY_ROOT_EXPECT="200"                 # qué debe devolver GET /: "200", o "307:/login" si exige sesión

# Caddy central del VPS (compartido por todos los proyectos; TLS termina ahí).
# Corre en network_mode: host ⇒ NO hay red docker compartida con los proyectos
# (docker rechaza conectar un contenedor en modo host a una red bridge) y llega a
# la app por loopback. Por eso el upstream es 127.0.0.1:$WEB_PORT y nunca un
# nombre de servicio docker: "web:3000" no resolvería. Ver SKILL.md §Topología.
CADDY_DIR="/home/developer/infra/caddy"  # dir del compose del Caddy central en el VPS
CADDY_CONTAINER="edge-caddy"             # nombre del contenedor del Caddy central
CADDY_UPSTREAM="127.0.0.1:$WEB_PORT"     # a qué proxya el bloque del Caddyfile

# ── Rutas de datos en el VPS ──────────────────────────────────────────────────
BACKUP_DIR="/home/developer/backups/$PROJECT_NAME"
MIGRATIONS_DIR="packages/db/drizzle"     # dónde viven las migraciones (rollback.sh mira este tramo)

# ── Autodetección (normalmente no hace falta tocar nada) ─────────────────────
# Los scripts detectan solos si corren EN el VPS (deploy local) o en una máquina
# de desarrollo (deploy remoto). Orden: DEPLOY_MODE > /etc/deploy-target > ruta
# del repo == REMOTE_DIR > hostname == VPS_HOSTNAME.
#DEPLOY_MODE="local"                     # fuerza "local" o "remote" (o flag --local/--remote)
#VPS_HOSTNAME=""                         # hostname del VPS, si quieres detectar por hostname
