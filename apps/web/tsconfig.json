{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2023"],
    "types": ["node"],
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "resolveJsonModule": true,
    "plugins": [{ "name": "next" }],
    // `@/` → src/. NO hay paths que crucen paquetes: `@app/core` se resuelve por
    // su exports map + workspace:* (tooling.md §4).
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
