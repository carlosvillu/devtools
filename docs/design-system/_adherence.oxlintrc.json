{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/chain/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/history/**",
              "components/overlay/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|tone|icon|mono|size|outline|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: kind, tone, icon, mono, size, outline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|block|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, block."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|icon|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: tone, title, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|warning|danger|success|security)$/]",
        "message": "<Callout> tone must be one of 'info' | 'warning' | 'danger' | 'success' | 'security'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|inset|hover|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, inset, hover."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChainSummary'] > JSXAttribute > JSXIdentifier[name!=/^(?:kinds|size|key|ref|className|style|children)$/]",
        "message": "<ChainSummary> doesn't accept that prop. Declared props: kinds, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChainSummary'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<ChainSummary> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|value|title|kind|wrap|copyable|maxHeight|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: children, value, title, kind, wrap, copyable, maxHeight."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfidenceBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|showValue|width|key|ref|className|style|children)$/]",
        "message": "<ConfidenceBar> doesn't accept that prop. Declared props: value, showValue, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='CopyButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|size|withLabel|onCopy|key|ref|className|style|children)$/]",
        "message": "<CopyButton> doesn't accept that prop. Declared props: value, label, size, withLabel, onCopy."
      },
      {
        "selector": "JSXOpeningElement[name.name='CopyButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<CopyButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onOpenChange|onConfirm|title|description|confirmLabel|cancelLabel|confirmTone|children|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onOpenChange, onConfirm, title, description, confirmLabel, cancelLabel, confirmTone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|htmlFor|hint|error|required|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, htmlFor, hint, error, required, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HistoryRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:preview|kind|chain|time|onReopen|onDelete|key|ref|className|style|children)$/]",
        "message": "<HistoryRow> doesn't accept that prop. Declared props: preview, kind, chain, time, onReopen, onDelete."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|variant|size|active|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, variant, size, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|secondary)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Image'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|ratio|radius|fit|bordered|caption|icon|key|ref|className|style|children)$/]",
        "message": "<Image> doesn't accept that prop. Declared props: src, alt, ratio, radius, fit, bordered, caption, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Image'] > JSXAttribute[name.name='ratio'] > Literal[value!=/^(?:auto|square|video|wide|portrait)$/]",
        "message": "<Image> ratio must be one of 'auto' | 'square' | 'video' | 'wide' | 'portrait'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Image'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:none|sm|md|lg|xl|full)$/]",
        "message": "<Image> radius must be one of 'none' | 'sm' | 'md' | 'lg' | 'xl' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Image'] > JSXAttribute[name.name='fit'] > Literal[value!=/^(?:cover|contain)$/]",
        "message": "<Image> fit must be one of 'cover' | 'contain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|invalid|mono|icon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size, invalid, mono, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kbd'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Kbd> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|kind|confidence|applied|alternatives|transforms|output|notes|terminal|onSelectTransform|key|ref|className|style|children)$/]",
        "message": "<StepCard> doesn't accept that prop. Declared props: index, kind, confidence, applied, alternatives, transforms, output, notes, terminal, onSelectTransform."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:invalid|mono|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: invalid, mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|blink|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: size, blink."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
